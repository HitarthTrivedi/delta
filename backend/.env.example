# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./delta.db

# --- API Keys ---
# Replace with your actual keys for production
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# --- Authentication ---
# (Clerk is bypassed in Demo Mode, but keys go here if reinstated)
CLERK_SECRET_KEY=your_clerk_secret_here
CLERK_PUBLISHABLE_KEY=your_clerk_pub_here

# --- Email ---
# NOTE: plain SMTP does NOT work on Railway — outbound ports 25/465/587 are
# blocked, so smtplib just hangs (see commit dd8faff). Both transports below
# send over HTTPS/443 instead.

# Gmail API (preferred — our own mailbox, no third-party provider).
# Google Cloud Console -> APIs & Services:
#   1. Enable the Gmail API
#   2. OAuth consent screen -> External -> add yourself as a Test user
#   3. Credentials -> OAuth client ID -> Desktop app -> copy ID + secret
#   4. Generate a refresh token with scope https://www.googleapis.com/auth/gmail.send
#      (OAuth Playground: gear icon -> "Use your own OAuth credentials")
# Free @gmail.com sending cap is ~500 recipients/day.
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_FROM_EMAIL=alphakore5@gmail.com
GMAIL_FROM_NAME=Delta by Alpha.Kore

# Brevo (fallback — used only when GMAIL_REFRESH_TOKEN is empty).
# Sender must be verified: Senders, Domains & Dedicated IPs -> Senders.
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM_EMAIL=alphakore5@gmail.com
BREVO_FROM_NAME=Delta by Alpha.Kore

# --- Daily reminders ---
# No external cron. The sweep fires on the first user request at/after
# REMINDER_HOUR_LOCAL, so it still works on a free tier that sleeps when idle:
# whoever opens the app in the morning wakes the server and triggers the send.
# Sent at most once per user per day (enforced in the DB, not in memory).
REMINDERS_ENABLED=true
REMINDER_TIMEZONE=Asia/Kolkata   # hour below is interpreted in this timezone
REMINDER_HOUR_LOCAL=9            # first visit at/after 9am local sends the batch
REMINDER_CHECK_INTERVAL_SECONDS=900
# Shared secret for the manual test trigger: POST /api/reminders/daily
REMINDER_SECRET=generate_a_long_random_string

# --- Frontend (used for links inside emails) ---
FRONTEND_URL=https://delta-ai.vercel.app
